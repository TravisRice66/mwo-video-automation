{
  "input": "output/youtube_metadata_updates.csv",
  "defaults_json": "config/youtube_metadata_defaults.sample.json",
  "results_csv": "output/youtube_metadata_update_results_{timestamp}.csv",
  "user_data_dir": ".playwright/youtube-studio-profile",
  "start_row": 1,
  "limit": 0,
  "max_retries": 3,
  "retry_base_delay_seconds": 1.2,
  "retry_max_delay_seconds": 20,
  "retry_jitter_seconds": 0.8,
  "retry_transient_only": true,
  "checkpoint_every": 10,
  "refresh_every": 50,
  "stop_after_consecutive_failures": 5,
  "capture_failure_artifacts": true,
  "save_failure_html": false,
  "trace_on_failure": false,
  "openai_recovery": false,
  "openai_model": "gpt-5-mini",
  "openai_timeout_seconds": 20.0,
  "failure_artifacts_dir": "output/youtube_metadata_failure_artifacts/{timestamp}",
  "tags_mode": "replace",
  "playlist_mode": "replace",
  "headless": false,
  "dry_run": false
}
